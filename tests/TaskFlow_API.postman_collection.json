    {
      "name": "Create Task (Invalid - Too Short)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test(\"Validation error is returned\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.error).to.include(\"minlength\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"No\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/tasks",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "tasks"
          ]
        },
        "description": "Attempts to create a task with text length < 3. Should trigger Mongoose minlength validation and return 400 Bad Request."
      },
      "response": []
    },
