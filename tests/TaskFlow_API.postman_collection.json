    {
      "name": "Update Task (Valid)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify update properties and timestamp change\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.text).to.eql(\"Learn Express, Mongoose & MongoDB Atlas\");",
              "    pm.expect(jsonData.completed).to.eql(true);",
              "    pm.expect(jsonData.lastModified).to.not.eql(jsonData.createdAt);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Learn Express, Mongoose & MongoDB Atlas\",\n  \"completed\": true\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/tasks/{{task_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "tasks",
            "{{task_id}}"
          ]
        },
        "description": "Updates task text and completed status. Verifies that lastModified is updated."
      },
      "response": []
