      "response": []
    },
    {
      "name": "Create Task 1 (Express)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has id and defaults\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('_id');",
              "    pm.expect(jsonData.text).to.eql(\"Learn Express and Mongoose\");",
              "    pm.expect(jsonData.completed).to.eql(false);",
              "    pm.expect(jsonData).to.have.property('createdAt');",
              "    pm.expect(jsonData).to.have.property('lastModified');",
              "    // Save ID for subsequent requests",
              "    pm.globals.set(\"task_id\", jsonData._id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Learn Express and Mongoose\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/tasks",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "tasks"
          ]
        },
        "description": "Creates a task. Checks that defaults (completed=false, createdAt, lastModified) are set by the DB."
      },
      "response": []
    },
