    },
    {
      "name": "Create Task (Valid)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response returns the created task\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData.text).to.eql(\"Learn Node.js and Express\");",
              "    pm.expect(jsonData.completed).to.eql(false);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Learn Node.js and Express\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/tasks",
          "protocol": "http",
          "host": [
            "localhost"
