    {
      "name": "Get Paginated Tasks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Pagination body format is correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('tasks');",
              "    pm.expect(jsonData).to.have.property('totalPages');",
              "    pm.expect(jsonData.currentPage).to.eql(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/tasks?page=1&limit=2",
          "protocol": "http",
          "host": [
